     "\[IndentingNewLine]", 
     RowBox[{"c", "=", 
      RowBox[{"{", "}"}]}], ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"(*", " ", 
      RowBox[{
      "Pad", " ", "storage", " ", "arrays", " ", "as", " ", "necessary"}], 
      " ", "*)"}], "\[IndentingNewLine]", 
     RowBox[{"atmp", " ", "=", " ", 
      RowBox[{"PadRight", "[", 
       RowBox[{"a", ",", "n"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"btmp", " ", "=", " ", 
      RowBox[{"PadRight", "[", 
       RowBox[{"b", ",", "n"}], "]"}]}], ";", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{"(*", "  ", 
      RowBox[{
       RowBox[{"Print", "[", 
        RowBox[{
        "\"\<a = \>\"", ",", " ", "atmp", ",", " ", "\"\<, b = \>\"", ",", 
         " ", "btmp", ",", " ", "\"\<, c = \>\"", ",", " ", "c"}], "]"}], 
       ";"}], " ", "*)"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"(*", " ", 
      RowBox[{
