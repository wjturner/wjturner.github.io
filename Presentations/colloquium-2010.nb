 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"Helper", " ", "Functions"}], " ", "*)"}], 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"rZeroMod", "[", 
      RowBox[{"f_", ",", "mod_", ",", "n_", ",", "omega_"}], "]"}], ":=", 
     RowBox[{
      RowBox[{"f", "[", 
       RowBox[{"[", 
