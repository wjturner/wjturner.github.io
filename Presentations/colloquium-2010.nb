Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"NewtonInverse", "[", 
    RowBox[{"f_", ",", "x_", ",", "l_"}], "]"}], ":=", 
   RowBox[{"Module", "[", "\[IndentingNewLine]", 
    RowBox[{"(*", " ", 
     RowBox[{
     "Requires", " ", "the", " ", "constant", " ", "term", " ", "of", " ", 
      "the", " ", "polynomial", " ", "f", " ", "to", " ", "be", " ", "1."}], 
     " ", "*)"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
    RowBox[{"(*", " ", 
     RowBox[{"Local", " ", "Variables"}], " ", "*)"}], "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"g", ",", " ", "r", ",", " ", "i"}], "}"}], ",", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"(*", " ", "Initialize", " ", "*)"}], "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"g", "=", "1"}], ";", "\[IndentingNewLine]", 
      RowBox[{"r", "=", 
       RowBox[{"Ceiling", "[", 
        RowBox[{"Log", "[", 
         RowBox[{"2", ",", "l"}], "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
      "\[IndentingNewLine]", 
      RowBox[{"For", "[", 
       RowBox[{
        RowBox[{"i", "=", "1"}], ",", " ", 
        RowBox[{"i", "\[LessEqual]", "r"}], ",", " ", 
        RowBox[{"++", "i"}], ",", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"g", "=", 
          RowBox[{"PolynomialRemainder", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"2", " ", "g"}], " ", "-", " ", 
             RowBox[{"f", " ", 
              SuperscriptBox["g", "2"]}]}], ",", 
            SuperscriptBox["x", 
             SuperscriptBox["2", "i"]], ",", "x"}], "]"}]}], ";"}]}], 
       "\[IndentingNewLine]", 
       RowBox[{"(*", " ", 
        RowBox[{"Print", "[", 
         RowBox[{
         "\"\<i = \>\"", ",", " ", "i", ",", " ", "\"\<, g = \>\"", ",", " ", 
          "g"}], "]"}], " ", "*)"}], "\[IndentingNewLine]", "]"}], ";", 
      "\[IndentingNewLine]", "\[IndentingNewLine]", "g"}]}], 
    "\[IndentingNewLine]", "]"}]}], ";"}]], "Input",
