Cell[CellGroupData[{

Cell["Fast Division Using Newton Iteration", "Subsection",
 CellChangeTimes->{{3.48157988834375*^9, 3.48157994459375*^9}, {
  3.481580384109375*^9, 3.481580387234375*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"FastPolynomialDivision", "[", 
    RowBox[{"a_", ",", "b_", ",", "x_"}], "]"}], ":=", 
   RowBox[{"If", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"Exponent", "[", 
       RowBox[{"a", ",", "x"}], "]"}], "<", 
      RowBox[{"Exponent", "[", 
       RowBox[{"b", ",", "x"}], "]"}]}], ",", "\[IndentingNewLine]", 
     RowBox[{"{", 
      RowBox[{"0", ",", "a"}], "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{"Module", "[", "\[IndentingNewLine]", 
      RowBox[{"(*", " ", 
       RowBox[{"Local", " ", "Variables"}], " ", "*)"}], 
      "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
        "dega", ",", "degb", ",", " ", "m", ",", "binv", ",", "qStar"}], 
        "}"}], ",", "\[IndentingNewLine]", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"dega", "=", 
         RowBox[{"Exponent", "[", 
          RowBox[{"a", ",", "x"}], "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"degb", "=", 
         RowBox[{"Exponent", "[", 
          RowBox[{"b", ",", "x"}], "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"m", "=", 
         RowBox[{"dega", "-", "degb"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"binv", "=", 
         RowBox[{"NewtonInverse", "[", 
          RowBox[{
           RowBox[{"Rev", "[", 
            RowBox[{"b", ",", "x", ",", "degb"}], "]"}], ",", "x", ",", 
           RowBox[{"m", "+", "1"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"qStar", "=", 
         RowBox[{"PolynomialRemainder", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"Rev", "[", 
             RowBox[{"a", ",", "x", ",", "dega"}], "]"}], " ", "binv"}], ",", 
           SuperscriptBox["x", 
            RowBox[{"m", "+", "1"}]], ",", "x"}], "]"}]}], ";", 
        "\[IndentingNewLine]", "\[IndentingNewLine]", 
        RowBox[{"q", "=", 
         RowBox[{"Rev", "[", 
          RowBox[{"qStar", ",", "x", ",", "m"}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"r", "=", 
         RowBox[{"Collect", "[", 
          RowBox[{
           RowBox[{"a", "-", 
            RowBox[{"b", " ", "q"}]}], ",", "x"}], "]"}]}], ";", 
        "\[IndentingNewLine]", "\[IndentingNewLine]", 
        RowBox[{"{", 
         RowBox[{"q", ",", "r"}], "}"}]}]}], "\[IndentingNewLine]", "]"}]}], 
    "\[IndentingNewLine]", "]"}]}], ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{
  3.481579978203125*^9, {3.48158047778125*^9, 3.481580479015625*^9}}],

