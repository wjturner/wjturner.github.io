Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"StoreInteger", "[", 
     RowBox[{"a_", ",", "r_"}], "]"}], ":=", 
    RowBox[{"Module", "[", "\[IndentingNewLine]", 
     RowBox[{"(*", " ", 
      RowBox[{"Local", " ", "variables"}], " ", "*)"}], "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"digits", ",", " ", "A"}], "}"}], ",", "\[IndentingNewLine]", 
      "\[IndentingNewLine]", 
      RowBox[{"(*", " ", 
       RowBox[{"Initialize", " ", "local", " ", "variables"}], " ", "*)"}], 
      "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"A", " ", "=", "a"}], ";", "\[IndentingNewLine]", 
       RowBox[{"digits", " ", "=", " ", 
        RowBox[{"{", "}"}]}], ";", "\[IndentingNewLine]", 
       "\[IndentingNewLine]", 
       RowBox[{"(*", " ", 
        RowBox[{"Build", " ", "digit", " ", "list"}], " ", "*)"}], 
       "\[IndentingNewLine]", 
       RowBox[{"While", "[", 
        RowBox[{
         RowBox[{"A", ">", "0"}], ",", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"AppendTo", "[", 
           RowBox[{"digits", ",", 
            RowBox[{"Mod", "[", 
             RowBox[{"A", ",", "r"}], "]"}]}], "]"}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"A", " ", "=", " ", 
           RowBox[{"Quotient", "[", 
            RowBox[{"A", ",", "r"}], "]"}]}], ";"}]}], "\[IndentingNewLine]", 
        "]"}], ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
       RowBox[{"(*", " ", 
