       RowBox[{
        RowBox[{"AppendTo", "[", 
         RowBox[{"c", ",", 
          RowBox[{
           RowBox[{"atmp", "[", 
            RowBox[{"[", "i", "]"}], "]"}], "+", 
           RowBox[{"btmp", "[", 
