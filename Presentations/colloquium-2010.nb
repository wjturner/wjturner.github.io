Cell[CellGroupData[{

Cell["Polynomial Equations", "Subsection",
 CellChangeTimes->{{3.481583010734375*^9, 3.481583033953125*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"PolynomialNewtonIteration", "[", 
    RowBox[{"phi_", ",", "x_", ",", "l_", ",", "gZero_", ",", "sZero_"}], 
    "]"}], ":=", 
   RowBox[{"Module", "[", "\[IndentingNewLine]", 
    RowBox[{"(*", " ", 
     RowBox[{"Local", " ", "variables"}], " ", "*)"}], "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"r", ",", "i", ",", "g", ",", "s"}], "}"}], ",", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"r", "=", 
       RowBox[{"Ceiling", "[", 
        RowBox[{"Log", "[", 
         RowBox[{"2", ",", "l"}], "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"g", "=", "gZero"}], ";", "\[IndentingNewLine]", 
      RowBox[{"s", "=", "sZero"}], ";", "\[IndentingNewLine]", 
      RowBox[{"For", "[", 
       RowBox[{
        RowBox[{"i", "=", "1"}], ",", " ", 
        RowBox[{"i", "<", "r"}], ",", " ", 
        RowBox[{"++", "i"}], ",", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"g", "=", 
          RowBox[{"PolynomialRemainder", "[", 
           RowBox[{
            RowBox[{"(", " ", 
             RowBox[{"g", "-", 
              RowBox[{
               RowBox[{"phi", "[", "g", "]"}], "s"}]}], ")"}], ",", 
            SuperscriptBox["x", 
             SuperscriptBox["2", "i"]], ",", "x"}], "]"}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"s", "=", 
          RowBox[{"PolynomialRemainder", "[", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{
              RowBox[{"2", " ", "s"}], "-", 
