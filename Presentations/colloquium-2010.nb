              "omega"}], "]"}], ",", "mod", ",", 
            RowBox[{"n", "/", "2"}], ",", 
            SuperscriptBox["omega", "2"]}], "]"}], ",", 
          RowBox[{"FFTmod", "[", 
           RowBox[{
            RowBox[{"rOneStarMod", "[", 
             RowBox[{
              RowBox[{"PadRight", "[", 
               RowBox[{"f", ",", "n"}], "]"}], ",", "mod", ",", "n", ",", 
              "omega"}], "]"}], ",", "mod", ",", 
            RowBox[{"n", "/", "2"}], ",", 
            SuperscriptBox["omega", "2"]}], "]"}]}], "\[IndentingNewLine]", 
         "]"}], "]"}]}], "\[IndentingNewLine]", "]"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"InverseFFTmod", "[", 
