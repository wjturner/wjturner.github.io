         RowBox[{
          RowBox[{"n", "/", "2"}], "+", "1"}], ";;", "n"}], "]"}], "]"}]}]}], 
    ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"rOneStarMod", "[", 
      RowBox[{"f_", ",", "mod_", ",", "n_", ",", "omega_"}], "]"}], ":=", 
     RowBox[{"Mod", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{"f", "[", 
           RowBox[{"[", 
            RowBox[{"1", ";;", 
             RowBox[{"n", "/", "2"}]}], "]"}], "]"}], "-", 
          RowBox[{"f", "[", 
           RowBox[{"[", 
            RowBox[{
             RowBox[{
              RowBox[{"n", "/", "2"}], "+", "1"}], ";;", "n"}], "]"}], 
           "]"}]}], ")"}], " ", 
        RowBox[{"Table", "[", 
         RowBox[{
          SuperscriptBox["omega", "i"], ",", 
          RowBox[{"{", 
           RowBox[{"i", ",", "0", ",", 
            RowBox[{
             RowBox[{"n", "/", "2"}], "-", "1"}]}], "}"}]}], "]"}]}], ",", 
       "mod"}], "]"}]}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"FFTmod", "[", 
      RowBox[{"f_", ",", "mod_", ",", "n_", ",", "omega_"}], "]"}], ":=", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"n", "\[Equal]", "1"}], ",", "\[IndentingNewLine]", "f", ",", 
       "\[IndentingNewLine]", 
       RowBox[{"Simplify", "[", 
        RowBox[{"Riffle", "[", 
         RowBox[{
          RowBox[{"FFTmod", "[", 
